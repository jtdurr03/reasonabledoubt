# Engine B (step four) configuration. Copy to .env and fill in, or export these
# in your shell. Only `npm run bake` needs the API key; the runner, the tests,
# and everything else run offline.

# Required for baking: your Anthropic API key. Read from the environment by the
# SDK, never hardcoded. Do not commit a real key.
ANTHROPIC_API_KEY=sk-ant-...

# The model that performs the character voice (the chat pulls). Default:
# claude-sonnet-4-6, for audibly distinct witnesses. Use claude-haiku-4-5 for a
# cheaper, flatter voice.
ENGINE_B_PERFORMER_MODEL=claude-sonnet-4-6

# The cheaper, faster model that runs the leak verifier. Default: claude-haiku-4-5.
ENGINE_B_VERIFIER_MODEL=claude-haiku-4-5

# Note: the case-bible build (Engine A, step five) will use claude-opus-4-8.
